{
  "name": "dropconvert-wasm",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22.16.0",
    "pnpm": "^10.26.1"
  },
  "volta": {
    "node": "24.14.0",
    "pnpm": "10.26.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "rollup": "4.59.0",
      "minimatch": "10.2.4"
    }
  },
  "scripts": {
    "dev": "vite",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "licenses:generate": "tsx scripts/generate-third-party-licenses.ts",
    "prebuild": "pnpm -s licenses:generate",
    "build": "vite build",
    "analyze": "vite build && echo '\nBundle analysis generated at dist/stats.html'",
    "preview": "vite preview",
    "clean": "rimraf dist node_modules/.vite",
    "quality": "pnpm -s lint && pnpm -s fmt:check && pnpm -s typecheck"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11"
  }
}
